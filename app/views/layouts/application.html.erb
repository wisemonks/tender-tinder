<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "🔥 Tender Tinder - Swipe Right on the Perfect Tender" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tender Tinder">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Google Fonts - modern UI sans + brand display %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Righteous&display=swap&subset=latin-ext" rel="stylesheet">

    <%# Tailwind CSS %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex flex-col min-h-screen">
    <header class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-4">
        <%= link_to root_path, class: "flex items-center gap-3 min-w-0" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 48 48" class="flex-shrink-0">
            <path fill="#DD2C00" d="M39,28c0,8.395-6.606,15-15.001,15S9,36.395,9,28S22.479,12.6,20.959,5C24,5,39,15.841,39,28z"/>
            <path fill="#FF5722" d="M33,32c0-7.599-9-15-9-15c0,6.08-9,8.921-9,15c0,5.036,3.963,9,9,9S33,37.036,33,32z"/>
            <path fill="#FFC107" d="M18.999,35.406C19,32,24,30.051,24,27c0,0,4.999,3.832,4.999,8.406c0,2.525-2.237,4.574-5,4.574S18.998,37.932,18.999,35.406z"/>
          </svg>
          <span class="text-xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-orange-500 via-red-500 to-pink-500 truncate" style="font-family: 'Righteous', sans-serif;">
            Tender Tinder
          </span>
        <% end %>

        <div class="flex items-center gap-3 text-sm">
          <% if user_signed_in? %>
            <span class="hidden sm:inline text-gray-600"><%= current_user.email %></span>
            <%= link_to "Nustatymai", settings_path, class: "px-3 py-2 text-gray-700 hover:text-red-600 transition-colors" %>
            <%= button_to "Atsijungti", destroy_user_session_path, method: :delete, class: "px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors" %>
          <% else %>
            <%= link_to "Prisijungti", new_user_session_path, class: "px-3 py-2 text-gray-700 hover:text-red-600 transition-colors" %>
            <%= link_to "Registruotis", new_user_registration_path, class: "px-4 py-2 bg-gradient-to-r from-orange-500 to-red-500 text-white rounded-lg hover:from-orange-600 hover:to-red-600 transition-colors" %>
          <% end %>
        </div>
      </div>
    </header>

    <% if notice || alert %>
      <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pt-4">
        <% if notice %>
          <div class="mb-3 p-4 bg-green-50 border border-green-200 text-green-800 rounded-lg"><%= notice %></div>
        <% end %>

        <% if alert %>
          <div class="mb-3 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg"><%= alert %></div>
        <% end %>
      </div>
    <% end %>

    <main class="flex-grow">
      <%= yield %>
    </main>
    <%= render "layouts/footer" %>
  </body>
</html>
