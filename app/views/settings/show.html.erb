<div class="min-h-screen bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 50 50" fill="currentColor" class="text-red-600">
            <path d="M 22.205078 2 A 1.0001 1.0001 0 0 0 21.21875 2.8378906 L 20.246094 8.7929688 C 19.076509 9.1331971 17.961243 9.5922728 16.910156 10.164062 L 11.996094 6.6542969 A 1.0001 1.0001 0 0 0 10.708984 6.7597656 L 6.8183594 10.646484 A 1.0001 1.0001 0 0 0 6.7070312 11.927734 L 10.164062 16.873047 C 9.583454 17.930271 9.1142098 19.051824 8.765625 20.232422 L 2.8359375 21.21875 A 1.0001 1.0001 0 0 0 2.0019531 22.205078 L 2.0019531 27.705078 A 1.0001 1.0001 0 0 0 2.8261719 28.691406 L 8.7597656 29.742188 C 9.1064607 30.920739 9.5727226 32.043065 10.154297 33.101562 L 6.6542969 37.998047 A 1.0001 1.0001 0 0 0 6.7597656 39.285156 L 10.648438 43.175781 A 1.0001 1.0001 0 0 0 11.927734 43.289062 L 16.882812 39.820312 C 17.936999 40.39548 19.054994 40.857928 20.228516 41.201172 L 21.21875 47.164062 A 1.0001 1.0001 0 0 0 22.205078 48 L 27.705078 48 A 1.0001 1.0001 0 0 0 28.691406 47.173828 L 29.751953 41.1875 C 30.920633 40.838997 32.033372 40.369697 33.082031 39.791016 L 38.070312 43.291016 A 1.0001 1.0001 0 0 0 39.351562 43.179688 L 43.240234 39.287109 A 1.0001 1.0001 0 0 0 43.34375 37.996094 L 39.787109 33.058594 C 40.355783 32.014958 40.813915 30.908875 41.154297 29.748047 L 47.171875 28.693359 A 1.0001 1.0001 0 0 0 47.998047 27.707031 L 47.998047 22.207031 A 1.0001 1.0001 0 0 0 47.160156 21.220703 L 41.152344 20.238281 C 40.80968 19.078827 40.350281 17.974723 39.78125 16.931641 L 43.289062 11.933594 A 1.0001 1.0001 0 0 0 43.177734 10.652344 L 39.287109 6.7636719 A 1.0001 1.0001 0 0 0 37.996094 6.6601562 L 33.072266 10.201172 C 32.023186 9.6248101 30.909713 9.1579916 29.738281 8.8125 L 28.691406 2.828125 A 1.0001 1.0001 0 0 0 27.705078 2 L 22.205078 2 z M 23.056641 4 L 26.865234 4 L 27.861328 9.6855469 A 1.0001 1.0001 0 0 0 28.603516 10.484375 C 30.066026 10.848832 31.439607 11.426549 32.693359 12.185547 A 1.0001 1.0001 0 0 0 33.794922 12.142578 L 38.474609 8.7792969 L 41.167969 11.472656 L 37.835938 16.220703 A 1.0001 1.0001 0 0 0 37.796875 17.310547 C 38.548366 18.561471 39.118333 19.926379 39.482422 21.380859 A 1.0001 1.0001 0 0 0 40.291016 22.125 L 45.998047 23.058594 L 45.998047 26.867188 L 40.279297 27.871094 A 1.0001 1.0001 0 0 0 39.482422 28.617188 C 39.122545 30.069817 38.552234 31.434687 37.800781 32.685547 A 1.0001 1.0001 0 0 0 37.845703 33.785156 L 41.224609 38.474609 L 38.53125 41.169922 L 33.791016 37.84375 A 1.0001 1.0001 0 0 0 32.697266 37.808594 C 31.44975 38.567585 30.074755 39.148028 28.617188 39.517578 A 1.0001 1.0001 0 0 0 27.876953 40.3125 L 26.867188 46 L 23.052734 46 L 22.111328 40.337891 A 1.0001 1.0001 0 0 0 21.365234 39.53125 C 19.90185 39.170557 18.522094 38.59371 17.259766 37.835938 A 1.0001 1.0001 0 0 0 16.171875 37.875 L 11.46875 41.169922 L 8.7734375 38.470703 L 12.097656 33.824219 A 1.0001 1.0001 0 0 0 12.138672 32.724609 C 11.372652 31.458855 10.793319 30.079213 10.427734 28.609375 A 1.0001 1.0001 0 0 0 9.6328125 27.867188 L 4.0019531 26.867188 L 4.0019531 23.052734 L 9.6289062 22.117188 A 1.0001 1.0001 0 0 0 10.435547 21.373047 C 10.804273 19.898143 11.383325 18.518729 12.146484 17.255859 A 1.0001 1.0001 0 0 0 12.111328 16.164062 L 8.8261719 11.46875 L 11.523438 8.7734375 L 16.185547 12.105469 A 1.0001 1.0001 0 0 0 17.28125 12.148438 C 18.536908 11.394293 19.919867 10.822081 21.384766 10.462891 A 1.0001 1.0001 0 0 0 22.132812 9.6523438 L 23.056641 4 z M 25 17 C 20.593567 17 17 20.593567 17 25 C 17 29.406433 20.593567 33 25 33 C 29.406433 33 33 29.406433 33 25 C 33 20.593567 29.406433 17 25 17 z M 25 19 C 28.325553 19 31 21.674447 31 25 C 31 28.325553 28.325553 31 25 31 C 21.674447 31 19 28.325553 19 25 C 19 21.674447 21.674447 19 25 19 z"/>
          </svg>
          <div>
            <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-orange-500 via-red-500 to-pink-500" style="font-family: 'Righteous', sans-serif;">
              Nustatymai
            </h1>
            <p class="text-sm text-gray-500 mt-1">Atrankos taisyklės rezultatams ir kasdienei santraukai</p>
          </div>
        </div>
        <%= link_to root_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-white text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition-colors font-medium" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          <span>Grįžti</span>
        <% end %>
      </div>
    </div>

    <% if notice %>
      <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded-lg">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg">
        <%= alert %>
      </div>
    <% end %>

    <!-- Settings Form -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
      <%= form_with url: settings_path, method: :patch, scope: :settings, class: "p-6 space-y-6" do |f| %>

        <!-- Status Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Pirkimo būsena
          </label>
          <%= f.select :status,
            options_for_select(@status_options, @settings["status"]&.value),
            {},
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
          <p class="mt-1 text-sm text-gray-500">Rodomi tik šią būseną atitinkantys pirkimai</p>
        </div>

        <!-- Contract Type Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Pirkimo objekto tipas
          </label>
          <%= f.select :contract_type,
            options_for_select(@contract_type_options, @settings["contract_type"]&.value),
            {},
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
          <p class="mt-1 text-sm text-gray-500">Pasirinkite, jei norite matyti tik paslaugas, darbus arba prekes</p>
        </div>

        <!-- Procedure Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Pirkimo būdas
          </label>
          <%= f.select :procedure,
            options_for_select(@procedure_options, @settings["procedure"]&.value),
            {},
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
          <p class="mt-1 text-sm text-gray-500">Naudinga, jei sekate tik konkrečias pirkimo procedūras</p>
        </div>

        <!-- CPC Category Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            SPK kategorija
          </label>
          <%= f.select :cpc_category,
            options_for_select(@cpc_category_options, @settings["cpc_category"]&.value),
            {},
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
          <p class="mt-1 text-sm text-gray-500">Kai SPK žinoma, rodysime tik atitinkančias kategorijas</p>
        </div>

        <!-- Keywords -->
        <div class="border-t pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Raktažodžiai</h3>
          <div class="rounded-2xl border border-orange-100 bg-gradient-to-r from-orange-50 to-red-50 p-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Ko ieškoti pirkimų tekste
            </label>
            <%= f.text_area :keywords,
              value: @settings["keywords"]&.value,
              rows: 5,
              placeholder: "saulės elektrinė
IT priežiūra
kibernetinis saugumas",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
            <p class="mt-2 text-sm text-gray-600 leading-6">Įrašykite po vieną raktažodį kiekvienoje eilutėje arba atskirkite kableliais. Pirkimas bus atrinktas, jei bent vienas raktažodis bus rastas pavadinime, aprašyme, vykdytojo pavadinime, procedūroje, SPK, BVPŽ ar kituose išsaugotuose laukuose.</p>
          </div>
        </div>

        <!-- Publication Date Range -->
        <div class="border-t pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Paskelbimo data</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Nuo
              </label>
              <%= f.date_field :publication_from_date,
                value: @settings["publication_from_date"]&.value,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Iki
              </label>
              <%= f.date_field :publication_to_date,
                value: @settings["publication_to_date"]&.value,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
            </div>
          </div>
        </div>

        <!-- Submission Deadline Range -->
        <div class="border-t pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Pasiūlymų terminas</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Nuo
              </label>
              <%= f.date_field :submission_from_date,
                value: @settings["submission_from_date"]&.value,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Iki
              </label>
              <%= f.date_field :submission_to_date,
                value: @settings["submission_to_date"]&.value,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
            </div>
          </div>
        </div>

        <!-- Estimated Value Range -->
        <div class="border-t pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Numatoma vertė (EUR)</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Minimumas
              </label>
              <%= f.number_field :estimated_value_min,
                value: @settings["estimated_value_min"]&.value,
                step: "0.01",
                placeholder: "0.00",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Maksimumas
              </label>
              <%= f.number_field :estimated_value_max,
                value: @settings["estimated_value_max"]&.value,
                step: "0.01",
                placeholder: "0.00",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
            </div>
          </div>
        </div>

        <!-- Digest Emails -->
        <div class="border-t pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">
            <span class="inline-flex items-center gap-2">
              <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
              Kasdienės el. pašto santraukos gavėjai
            </span>
          </h3>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              El. pašto adresai (atskirti kableliais)
            </label>
            <%= f.text_area :digest_emails,
              value: @settings["digest_emails"]&.value,
              rows: 3,
              placeholder: "example1@email.com, example2@email.com, example3@email.com",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent font-mono text-sm" %>
            <p class="mt-2 text-sm text-gray-500">Įveskite vieną ar kelis el. pašto adresus, atskirtus kableliais. Gavėjai kiekvieną dieną gaus tik jūsų taisykles atitinkančių naujų pirkimų santrauką.</p>
          </div>
        </div>

        <!-- Submit Button -->
        <div class="border-t pt-6">
          <%= f.submit "Išsaugoti nustatymus", class: "w-full px-6 py-3 bg-gradient-to-r from-orange-500 to-red-500 text-white rounded-lg hover:from-orange-600 hover:to-red-600 focus:ring-2 focus:ring-red-500 focus:ring-offset-2 cursor-pointer font-semibold shadow-lg hover:shadow-xl transition-all" %>
        </div>
      <% end %>
    </div>

    <!-- Info Box -->
    <div class="mt-6 p-5 bg-gradient-to-r from-orange-50 to-red-50 border-2 border-red-200 rounded-xl">
      <h3 class="text-base font-bold text-red-900 mb-3 flex items-center gap-2">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        Kaip tai veikia
      </h3>
      <ul class="text-sm text-red-900 space-y-2 list-disc list-inside">
        <li>Sistema surenka visus prieinamus pirkimus iš <code class="bg-red-100 px-2 py-1 rounded font-mono text-xs">viesiejipirkimai.lt</code>, o šie nustatymai sprendžia, ką matysite jūs</li>
        <li>Palikite filtrus tuščius, jei norite matyti visą surinktą srautą</li>
        <li>Raktažodžiai padeda atrinkti tik jūsų sričiai aktualius pirkimus ir el. laiškus</li>
        <li>Išsaugoti pakeitimai pradedami taikyti iš karto jau surinktiems duomenims ir kitam nuskaitymo ciklui</li>
        <li>Galite paleisti rankiniu būdu su: <code class="bg-red-100 px-2 py-1 rounded font-mono text-xs">rails runner "ScrapeListJob.new.perform"</code></li>
      </ul>
    </div>
  </div>
</div>
