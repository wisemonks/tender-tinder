<%= render "devise/shared/auth_shell",
  title: "Susikurkite paskyrą",
  subtitle: "Turėsite savo atrinktų pirkimų sąrašą, pažymėtus įrašus ir asmeninius filtrus bei kasdienę el. pašto santrauką.",
  eyebrow: "Registracija" do %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <div>
      <%= f.label :email, "El. paštas", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-3 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:border-red-400 focus:ring-4 focus:ring-red-100 outline-none transition-shadow", placeholder: "jusu@imone.lt" %>
    </div>

    <div>
      <div class="flex items-center justify-between gap-3 mb-2">
        <%= f.label :password, "Slaptažodis", class: "block text-sm font-medium text-gray-700" %>
        <% if @minimum_password_length %>
          <span class="text-xs font-semibold uppercase tracking-[0.15em] text-gray-400">Min. <%= @minimum_password_length %> simboliai</span>
        <% end %>
      </div>
      <div data-controller="password-visibility" class="relative">
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-3 pr-14 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:border-red-400 focus:ring-4 focus:ring-red-100 outline-none transition-shadow", placeholder: "Sukurkite stiprų slaptažodį", data: { password_visibility_target: "input" } %>
        <%= render "devise/shared/password_toggle_button" %>
      </div>
    </div>

    <div>
      <%= f.label :password_confirmation, "Pakartokite slaptažodį", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div data-controller="password-visibility" class="relative">
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-3 pr-14 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:border-red-400 focus:ring-4 focus:ring-red-100 outline-none transition-shadow", placeholder: "Pakartokite slaptažodį", data: { password_visibility_target: "input" } %>
        <%= render "devise/shared/password_toggle_button" %>
      </div>
    </div>

    <div class="rounded-2xl border border-orange-100 bg-orange-50 px-4 py-3 text-sm text-gray-700 leading-6">
      Sukūrę paskyrą galėsite valdyti savo paieškos filtrus, kasdien gauti naujų pirkimų santrauką el. paštu ir pažymėti svarbiausius pirkimus.
    </div>

    <%= f.submit "Sukurti paskyrą", class: "w-full inline-flex justify-center items-center gap-2 px-6 py-3.5 rounded-xl bg-gradient-to-r from-orange-500 via-red-500 to-pink-500 text-white font-semibold shadow-lg shadow-red-200 hover:from-orange-600 hover:via-red-600 hover:to-pink-600 transition-all" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
