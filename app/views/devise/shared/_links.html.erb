<div class="mt-8 border-t border-gray-200 pt-6 space-y-3 text-sm text-gray-600">
  <% if controller_name != "sessions" %>
    <div>
      Jau turite paskyrą?
      <%= link_to "Prisijunkite", new_session_path(resource_name), class: "font-semibold text-red-600 hover:text-red-700" %>
    </div>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <div>
      Dar neturite paskyros?
      <%= link_to "Registruokitės", new_registration_path(resource_name), class: "font-semibold text-red-600 hover:text-red-700" %>
    </div>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <div>
      <%= link_to "Pamiršote slaptažodį?", new_password_path(resource_name), class: "font-semibold text-gray-700 hover:text-red-600" %>
    </div>
  <% end %>
</div>
