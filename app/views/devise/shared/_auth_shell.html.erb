<div class="min-h-[calc(100vh-9rem)] bg-gray-50 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-16 -left-16 h-72 w-72 rounded-full bg-orange-200/40 blur-3xl"></div>
    <div class="absolute top-1/3 -right-12 h-80 w-80 rounded-full bg-red-200/35 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 h-64 w-64 rounded-full bg-pink-200/30 blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-16">
    <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-8 items-stretch">
      <section class="relative rounded-[2rem] overflow-hidden border border-red-100 bg-gradient-to-br from-slate-950 via-slate-900 to-red-950 text-white shadow-2xl shadow-red-100/60">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(249,115,22,0.35),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(236,72,153,0.25),transparent_35%)]"></div>
        <div class="relative p-8 sm:p-10 lg:p-12 h-full flex flex-col justify-between gap-10">
          <div>
            <div class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-orange-100 shadow-lg shadow-black/10 backdrop-blur">
              <span class="text-xl">🔥</span>
              <span class="tracking-[0.2em] uppercase text-xs font-semibold">Tender Tinder paskyra</span>
            </div>

            <h1 class="mt-8 text-4xl sm:text-5xl font-bold leading-tight text-transparent bg-clip-text bg-gradient-to-r from-orange-300 via-red-200 to-pink-200" style="font-family: 'Righteous', sans-serif;">
              Atraskite pirkimus, kurie iš tiesų tinka.
            </h1>

            <p class="mt-6 max-w-xl text-base sm:text-lg text-slate-200 leading-8">
              Vienoje vietoje matysite jums atrinktus pirkimus, išsisaugosite svarbiausius ir valdysite savo paieškos nustatymus.
            </p>
          </div>

          <div class="grid sm:grid-cols-3 gap-4">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
              <div class="text-xs uppercase tracking-[0.2em] text-orange-200">Asmeniška</div>
              <div class="mt-2 text-sm text-slate-200">Jūsų atrinkti ir pažymėti pirkimai matomi tik jums.</div>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
              <div class="text-xs uppercase tracking-[0.2em] text-orange-200">Filtrai</div>
              <div class="mt-2 text-sm text-slate-200">Nusistatykite temas, kainas ir kitus kriterijus pagal savo poreikius.</div>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
              <div class="text-xs uppercase tracking-[0.2em] text-orange-200">Kasdien</div>
              <div class="mt-2 text-sm text-slate-200">Kasdien gausite naujų atrinktų pirkimų santrauką el. paštu.</div>
            </div>
          </div>
        </div>
      </section>

      <section class="relative bg-white/95 backdrop-blur rounded-[2rem] border border-gray-200 shadow-xl shadow-gray-200/70 overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-orange-500 via-red-500 to-pink-500"></div>
        <div class="p-8 sm:p-10">
          <div class="mb-8">
            <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-red-600">
              <span class="h-2 w-2 rounded-full bg-red-500"></span>
              <%= local_assigns.fetch(:eyebrow, "Paskyra") %>
            </div>
            <h2 class="mt-4 text-3xl font-bold text-gray-900"><%= title %></h2>
            <p class="mt-3 text-gray-500 leading-7"><%= subtitle %></p>
          </div>

          <%= render "devise/shared/error_messages", resource: resource %>
          <%= yield %>
        </div>
      </section>
    </div>
  </div>
</div>
