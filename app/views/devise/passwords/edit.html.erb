<%= render "devise/shared/auth_shell",
  title: "Sukurkite naują slaptažodį",
  subtitle: "Pasirinkite naują slaptažodį ir saugiai grįžkite prie savo paskyros.",
  eyebrow: "Naujas slaptažodis" do %>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
    <%= f.hidden_field :reset_password_token %>

    <div>
      <div class="flex items-center justify-between gap-3 mb-2">
        <%= f.label :password, "Naujas slaptažodis", class: "block text-sm font-medium text-gray-700" %>
        <% if @minimum_password_length %>
          <span class="text-xs font-semibold uppercase tracking-[0.15em] text-gray-400">Min. <%= @minimum_password_length %> simboliai</span>
        <% end %>
      </div>
      <div data-controller="password-visibility" class="relative">
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "w-full px-4 py-3 pr-14 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:border-red-400 focus:ring-4 focus:ring-red-100 outline-none transition-shadow", placeholder: "Sukurkite naują slaptažodį", data: { password_visibility_target: "input" } %>
        <%= render "devise/shared/password_toggle_button" %>
      </div>
    </div>

    <div>
      <%= f.label :password_confirmation, "Pakartokite naują slaptažodį", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div data-controller="password-visibility" class="relative">
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-3 pr-14 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:border-red-400 focus:ring-4 focus:ring-red-100 outline-none transition-shadow", placeholder: "Pakartokite naują slaptažodį", data: { password_visibility_target: "input" } %>
        <%= render "devise/shared/password_toggle_button" %>
      </div>
    </div>

    <%= f.submit "Išsaugoti naują slaptažodį", class: "w-full inline-flex justify-center items-center gap-2 px-6 py-3.5 rounded-xl bg-gradient-to-r from-orange-500 via-red-500 to-pink-500 text-white font-semibold shadow-lg shadow-red-200 hover:from-orange-600 hover:via-red-600 hover:to-pink-600 transition-all" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
