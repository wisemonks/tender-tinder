<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-3">
          <!-- Fire Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 48 48" class="flex-shrink-0">
            <path fill="#DD2C00" d="M39,28c0,8.395-6.606,15-15.001,15S9,36.395,9,28S22.479,12.6,20.959,5C24,5,39,15.841,39,28z"/>
            <path fill="#FF5722" d="M33,32c0-7.599-9-15-9-15c0,6.08-9,8.921-9,15c0,5.036,3.963,9,9,9S33,37.036,33,32z"/>
            <path fill="#FFC107" d="M18.999,35.406C19,32,24,30.051,24,27c0,0,4.999,3.832,4.999,8.406c0,2.525-2.237,4.574-5,4.574S18.998,37.932,18.999,35.406z"/>
          </svg>

          <div>
            <h1 class="text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-orange-500 via-red-500 to-pink-500" style="font-family: 'Righteous', sans-serif;">
              Tender Tinder
            </h1>
            <p class="text-sm text-gray-500 mt-1">Lietuvos viešieji pirkimai</p>
          </div>
        </div>

        <!-- Settings Icon -->
        <%= link_to settings_path, class: "flex items-center gap-2 px-4 py-2 text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors", title: "Nustatymai" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 50 50" fill="currentColor">
            <path d="M 22.205078 2 A 1.0001 1.0001 0 0 0 21.21875 2.8378906 L 20.246094 8.7929688 C 19.076509 9.1331971 17.961243 9.5922728 16.910156 10.164062 L 11.996094 6.6542969 A 1.0001 1.0001 0 0 0 10.708984 6.7597656 L 6.8183594 10.646484 A 1.0001 1.0001 0 0 0 6.7070312 11.927734 L 10.164062 16.873047 C 9.583454 17.930271 9.1142098 19.051824 8.765625 20.232422 L 2.8359375 21.21875 A 1.0001 1.0001 0 0 0 2.0019531 22.205078 L 2.0019531 27.705078 A 1.0001 1.0001 0 0 0 2.8261719 28.691406 L 8.7597656 29.742188 C 9.1064607 30.920739 9.5727226 32.043065 10.154297 33.101562 L 6.6542969 37.998047 A 1.0001 1.0001 0 0 0 6.7597656 39.285156 L 10.648438 43.175781 A 1.0001 1.0001 0 0 0 11.927734 43.289062 L 16.882812 39.820312 C 17.936999 40.39548 19.054994 40.857928 20.228516 41.201172 L 21.21875 47.164062 A 1.0001 1.0001 0 0 0 22.205078 48 L 27.705078 48 A 1.0001 1.0001 0 0 0 28.691406 47.173828 L 29.751953 41.1875 C 30.920633 40.838997 32.033372 40.369697 33.082031 39.791016 L 38.070312 43.291016 A 1.0001 1.0001 0 0 0 39.351562 43.179688 L 43.240234 39.287109 A 1.0001 1.0001 0 0 0 43.34375 37.996094 L 39.787109 33.058594 C 40.355783 32.014958 40.813915 30.908875 41.154297 29.748047 L 47.171875 28.693359 A 1.0001 1.0001 0 0 0 47.998047 27.707031 L 47.998047 22.207031 A 1.0001 1.0001 0 0 0 47.160156 21.220703 L 41.152344 20.238281 C 40.80968 19.078827 40.350281 17.974723 39.78125 16.931641 L 43.289062 11.933594 A 1.0001 1.0001 0 0 0 43.177734 10.652344 L 39.287109 6.7636719 A 1.0001 1.0001 0 0 0 37.996094 6.6601562 L 33.072266 10.201172 C 32.023186 9.6248101 30.909713 9.1579916 29.738281 8.8125 L 28.691406 2.828125 A 1.0001 1.0001 0 0 0 27.705078 2 L 22.205078 2 z M 23.056641 4 L 26.865234 4 L 27.861328 9.6855469 A 1.0001 1.0001 0 0 0 28.603516 10.484375 C 30.066026 10.848832 31.439607 11.426549 32.693359 12.185547 A 1.0001 1.0001 0 0 0 33.794922 12.142578 L 38.474609 8.7792969 L 41.167969 11.472656 L 37.835938 16.220703 A 1.0001 1.0001 0 0 0 37.796875 17.310547 C 38.548366 18.561471 39.118333 19.926379 39.482422 21.380859 A 1.0001 1.0001 0 0 0 40.291016 22.125 L 45.998047 23.058594 L 45.998047 26.867188 L 40.279297 27.871094 A 1.0001 1.0001 0 0 0 39.482422 28.617188 C 39.122545 30.069817 38.552234 31.434687 37.800781 32.685547 A 1.0001 1.0001 0 0 0 37.845703 33.785156 L 41.224609 38.474609 L 38.53125 41.169922 L 33.791016 37.84375 A 1.0001 1.0001 0 0 0 32.697266 37.808594 C 31.44975 38.567585 30.074755 39.148028 28.617188 39.517578 A 1.0001 1.0001 0 0 0 27.876953 40.3125 L 26.867188 46 L 23.052734 46 L 22.111328 40.337891 A 1.0001 1.0001 0 0 0 21.365234 39.53125 C 19.90185 39.170557 18.522094 38.59371 17.259766 37.835938 A 1.0001 1.0001 0 0 0 16.171875 37.875 L 11.46875 41.169922 L 8.7734375 38.470703 L 12.097656 33.824219 A 1.0001 1.0001 0 0 0 12.138672 32.724609 C 11.372652 31.458855 10.793319 30.079213 10.427734 28.609375 A 1.0001 1.0001 0 0 0 9.6328125 27.867188 L 4.0019531 26.867188 L 4.0019531 23.052734 L 9.6289062 22.117188 A 1.0001 1.0001 0 0 0 10.435547 21.373047 C 10.804273 19.898143 11.383325 18.518729 12.146484 17.255859 A 1.0001 1.0001 0 0 0 12.111328 16.164062 L 8.8261719 11.46875 L 11.523438 8.7734375 L 16.185547 12.105469 A 1.0001 1.0001 0 0 0 17.28125 12.148438 C 18.536908 11.394293 19.919867 10.822081 21.384766 10.462891 A 1.0001 1.0001 0 0 0 22.132812 9.6523438 L 23.056641 4 z M 25 17 C 20.593567 17 17 20.593567 17 25 C 17 29.406433 20.593567 33 25 33 C 29.406433 33 33 29.406433 33 25 C 33 20.593567 29.406433 17 25 17 z M 25 19 C 28.325553 19 31 21.674447 31 25 C 31 28.325553 28.325553 31 25 31 C 21.674447 31 19 28.325553 19 25 C 19 21.674447 21.674447 19 25 19 z"/>
          </svg>
          <span class="hidden sm:inline">Nustatymai</span>
        <% end %>
      </div>
    </div>

    <!-- Search Bar -->
    <div class="mb-6">
      <%= form_with url: procurements_path, method: :get, class: "w-full" do |f| %>
        <div class="flex gap-2">
          <%= f.text_field :query,
            value: params[:query],
            placeholder: "Ieškokite pagal pavadinimą, aprašymą, vykdytoją, būdą, BVPŽ arba ID...",
            class: "flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
          <%= f.submit "Ieškoti",
            class: "px-6 py-3 bg-gradient-to-r from-orange-500 to-red-500 text-white rounded-lg hover:from-orange-600 hover:to-red-600 focus:ring-2 focus:ring-red-500 focus:ring-offset-2 cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <!-- Filters -->
    <div class="mb-6 border-b border-gray-200">
      <nav class="flex -mb-px space-x-8">
        <%= link_to procurements_path,
          class: "inline-flex items-center gap-2 px-1 py-4 text-sm font-semibold border-b-2 transition-colors #{params[:starred].blank? && params[:query].blank? ? 'border-red-500 text-red-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
          <span>Atitikę pirkimai</span>
          <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-0.5 text-xs font-bold rounded-full <%= params[:starred].blank? && params[:query].blank? ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600' %>">
            <%= @total_count %>
          </span>
        <% end %>
        <%= link_to procurements_path(starred: true),
          class: "inline-flex items-center gap-2 px-1 py-4 text-sm font-semibold border-b-2 transition-colors #{params[:starred].present? ? 'border-red-500 text-red-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
          <span>Pažymėti ★</span>
          <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-0.5 text-xs font-bold rounded-full <%= params[:starred].present? ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600' %>">
            <%= @starred_count %>
          </span>
        <% end %>
      </nav>
    </div>

    <!-- Results Count -->
    <% if params[:query].present? %>
      <div class="mb-4 text-gray-600">
        Rasta <span class="font-semibold text-red-600"><%= @pagy.count %></span>
        <%= @pagy.count == 1 ? 'rezultatas' : 'rezultatai' %>
        <%= params[:starred].present? ? 'tarp pažymėtų' : 'tarp jūsų atrinktų pirkimų' %>
        pagal "<%= params[:query] %>"
      </div>
    <% end %>

    <!-- Procurements List -->
    <% if @procurements.any? %>
      <div
        data-controller="infinite-scroll"
        data-infinite-scroll-url-value="<%= procurements_path %>"
        data-infinite-scroll-page-value="<%= @pagy.page %>"
        data-infinite-scroll-has-more-value="<%= @pagy.next.present? %>"
      >
        <div class="space-y-4" data-infinite-scroll-target="container">
          <% @procurements.each do |procurement| %>
            <%= render 'procurement_card', procurement: procurement %>
          <% end %>
        </div>

        <!-- Loading Indicator -->
        <% if @pagy && @pagy.next %>
          <div data-infinite-scroll-target="loading" class="mt-8 text-center">
            <div class="inline-flex items-center gap-2 px-4 py-2 text-gray-600">
              <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span>Loading more procurements...</span>
            </div>
          </div>
        <% end %>

        <!-- End Message -->
        <div data-infinite-scroll-target="endMessage" class="hidden mt-8 text-center text-gray-500">
          <p>No more procurements to load</p>
        </div>
      </div>
    <% else %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
        <p class="text-gray-500 text-lg">
          <%= params[:starred].present? ? 'Dar neturite pažymėtų pirkimų.' : 'Kol kas neturite jūsų taisykles atitinkančių pirkimų.' %>
        </p>
        <% if params[:query].present? %>
          <p class="text-gray-400 mt-2">Pabandykite kitą paieškos frazę.</p>
        <% elsif params[:starred].blank? %>
          <p class="text-gray-400 mt-2">Paleiskite scrapingą arba palaukite kito suplanuoto atnaujinimo.</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
