<div class="min-h-screen bg-gray-50">
  <% starred = procurement_starred?(@procurement) %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header with Branding -->
    <div class="mb-6">
      <%= link_to procurements_path, class: "inline-flex items-center gap-2 mb-4 hover:opacity-80 transition-opacity" do %>
        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        <span class="text-red-600 hover:text-red-800 font-medium">Grįžti į sąrašą</span>
      <% end %>

      <div class="flex items-center gap-3">
        <!-- Fire Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" class="flex-shrink-0">
          <path fill="#DD2C00" d="M39,28c0,8.395-6.606,15-15.001,15S9,36.395,9,28S22.479,12.6,20.959,5C24,5,39,15.841,39,28z"/>
          <path fill="#FF5722" d="M33,32c0-7.599-9-15-9-15c0,6.08-9,8.921-9,15c0,5.036,3.963,9,9,9S33,37.036,33,32z"/>
          <path fill="#FFC107" d="M18.999,35.406C19,32,24,30.051,24,27c0,0,4.999,3.832,4.999,8.406c0,2.525-2.237,4.574-5,4.574S18.998,37.932,18.999,35.406z"/>
        </svg>

        <h1 class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-orange-500 via-red-500 to-pink-500" style="font-family: 'Righteous', sans-serif;">
          Tender Tinder
        </h1>
      </div>
    </div>

    <!-- Main Content -->
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-lg">
      <!-- Header -->
      <div class="bg-gradient-to-r from-orange-50 to-red-100 border-b-2 border-red-500 p-6">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <h1 class="text-3xl font-bold text-red-900 mb-3"><%= @procurement.title %></h1>
            <div class="mt-2">
              <span class="inline-block bg-gradient-to-r from-orange-500 to-red-500 text-white px-4 py-1.5 rounded-full text-sm font-semibold">
                ID: <%= @procurement.external_id %>
              </span>
              <% if @procurement.status %>
                <span class="inline-block ml-2 px-3 py-1 bg-orange-100 text-orange-800 rounded-full text-sm font-medium">
                  <%= @procurement.status %>
                </span>
              <% end %>
            </div>
          </div>

          <!-- Star Button -->
          <%= turbo_frame_tag "procurement_star_#{@procurement.id}" do %>
            <%= button_to toggle_starred_procurement_path(@procurement),
              method: :post,
              class: "text-4xl focus:outline-none" do %>
              <span class="inline-block transform transition-all duration-300 ease-out hover:scale-125 <%= starred ? 'text-red-500 drop-shadow-lg' : 'text-gray-300 hover:text-orange-500' %>" style="<%= starred ? 'filter: drop-shadow(0 0 8px rgba(239, 68, 68, 0.6));' : '' %>">
                <%= starred ? '★' : '☆' %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Details -->
      <div class="divide-y divide-gray-100">
        <div class="grid grid-cols-2 gap-px bg-gray-100">
          <div class="bg-white px-6 py-4">
            <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Pirkimo vykdytojas</div>
            <div class="text-base text-gray-900 font-medium"><%= @procurement.authority_name %></div>
          </div>

          <% if @procurement.estimated_value %>
            <div class="bg-white px-6 py-4">
              <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Numatoma vertė</div>
              <div class="text-lg text-green-600 font-bold">
                <%= number_to_currency(@procurement.estimated_value, unit: "€", format: "%n %u") %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="grid grid-cols-2 gap-px bg-gray-100">
          <% if @procurement.publication_date %>
            <div class="bg-white px-6 py-4">
              <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Paskelbimo data</div>
              <div class="text-base text-gray-900 font-medium"><%= @procurement.publication_date.strftime("%Y-%m-%d") %></div>
            </div>
          <% end %>

          <% if @procurement.deadline_date %>
            <div class="bg-white px-6 py-4">
              <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Pasiūlymų terminas</div>
              <div class="text-base text-red-600 font-semibold"><%= @procurement.deadline_date.strftime("%Y-%m-%d %H:%M") %></div>
            </div>
          <% end %>
        </div>

        <% if @procurement.plan_reference.present? || @procurement.cpc_category.present? %>
          <div class="grid grid-cols-2 gap-px bg-gray-100">
            <% if @procurement.plan_reference.present? %>
              <div class="bg-white px-6 py-4">
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Pirkimų suvestinės nuoroda</div>
                <div class="text-base text-gray-900"><%= @procurement.plan_reference %></div>
              </div>
            <% end %>

            <% if @procurement.cpc_category.present? %>
              <div class="bg-white px-6 py-4">
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">SPK kategorija</div>
                <div class="text-base text-gray-900"><%= @procurement.cpc_category %></div>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @procurement.procedure_type.present? || @procurement.contract_duration.present? %>
          <div class="grid grid-cols-2 gap-px bg-gray-100">
            <% if @procurement.procedure_type.present? %>
              <div class="bg-white px-6 py-4">
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Pirkimo būdas</div>
                <div class="text-base text-gray-900"><%= @procurement.procedure_type %></div>
              </div>
            <% end %>

            <% if @procurement.contract_duration.present? %>
              <div class="bg-white px-6 py-4">
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Sutarties trukmė</div>
                <div class="text-base text-gray-900"><%= @procurement.contract_duration %></div>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @procurement.evaluation_criteria.present? %>
          <div class="grid grid-cols-2 gap-px bg-gray-100">
            <div class="bg-white px-6 py-4">
              <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Pasiūlymų vertinimo kriterijai</div>
              <div class="text-base text-gray-900"><%= @procurement.evaluation_criteria %></div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- CPV Codes -->
      <% if @procurement.cpv_codes.present? %>
        <div class="bg-gray-50 px-6 py-4 border-t border-gray-200">
          <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">BVPŽ kodai</div>
          <div class="text-sm text-gray-700 leading-relaxed">
            <%= simple_format(@procurement.cpv_codes) %>
          </div>
        </div>
      <% end %>

      <!-- Description -->
      <% if @procurement.description.present? %>
        <div class="bg-gray-50 px-6 py-4 border-t border-gray-200">
          <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Aprašymas</div>
          <div class="text-sm text-gray-700 leading-relaxed">
            <%= simple_format(@procurement.description) %>
          </div>
        </div>
      <% end %>

      <!-- Footer with External Link -->
      <div class="bg-gray-50 px-6 py-4 border-t border-gray-200 rounded-b-xl">
        <% if @procurement.url %>
          <%= link_to @procurement.url, target: "_blank", class: "inline-flex items-center justify-center w-full px-6 py-3 bg-gradient-to-r from-orange-500 to-red-500 text-white text-base font-semibold rounded-lg hover:from-orange-600 hover:to-red-600 transition-colors" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Peržiūrėti viesiejipirkimai.lt
          <% end %>
        <% end %>
      </div>
    </div>

  </div>
</div>
