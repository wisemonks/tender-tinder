<div class="procurement-card bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-all duration-200" data-procurement-id="<%= procurement.id %>">
  <!-- Header -->
  <div class="bg-gradient-to-r from-orange-50 to-red-100 border-b-2 border-red-500 p-4">
    <div class="flex items-start justify-between gap-3">
      <%= link_to procurement_path(procurement), class: "flex-1 min-w-0" do %>
        <h3 class="text-lg font-semibold text-red-900 hover:text-red-700 transition-colors line-clamp-2">
          <%= procurement.title %>
        </h3>
      <% end %>

      <!-- Star Button -->
      <%= turbo_frame_tag "procurement_star_#{procurement.id}", class: "flex-shrink-0" do %>
        <%= button_to toggle_starred_procurement_path(procurement),
          method: :post,
          class: "text-2xl focus:outline-none" do %>
          <span class="inline-block transform transition-all duration-300 ease-out hover:scale-125 <%= procurement.is_starred? ? 'text-red-500 drop-shadow-lg' : 'text-gray-300 hover:text-orange-500' %>" style="<%= procurement.is_starred? ? 'filter: drop-shadow(0 0 8px rgba(239, 68, 68, 0.6));' : '' %>">
            <%= procurement.is_starred? ? '★' : '☆' %>
          </span>
        <% end %>
      <% end %>
    </div>

    <div class="mt-2">
      <span class="inline-block bg-gradient-to-r from-orange-500 to-red-500 text-white px-3 py-1 rounded-full text-xs font-semibold">
        ID: <%= procurement.external_id %>
      </span>
    </div>
  </div>

  <!-- Info Table -->
  <div class="divide-y divide-gray-100">
    <div class="grid grid-cols-2 gap-px bg-gray-100">
      <div class="bg-white px-4 py-3">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Pirkimo vykdytojas</div>
        <div class="text-sm text-gray-900 font-medium"><%= procurement.authority_name %></div>
      </div>

      <% if procurement.status.present? %>
        <div class="bg-white px-4 py-3">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Būsena</div>
          <div class="text-sm">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800">
              <%= procurement.status %>
            </span>
          </div>
        </div>
      <% end %>
    </div>

    <div class="grid grid-cols-2 gap-px bg-gray-100">
      <% if procurement.cpc_category.present? %>
        <div class="bg-white px-4 py-3">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">SPK kategorija</div>
          <div class="text-sm text-gray-900"><%= procurement.cpc_category %></div>
        </div>
      <% end %>

      <% if procurement.procedure_type.present? %>
        <div class="bg-white px-4 py-3">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Pirkimo būdas</div>
          <div class="text-sm text-gray-900"><%= procurement.procedure_type %></div>
        </div>
      <% end %>
    </div>

    <div class="grid grid-cols-2 gap-px bg-gray-100">
      <% if procurement.publication_date %>
        <div class="bg-white px-4 py-3">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Paskelbimo data</div>
          <div class="text-sm text-gray-900 font-medium"><%= procurement.publication_date.strftime("%Y-%m-%d") %></div>
        </div>
      <% end %>

      <% if procurement.deadline_date %>
        <div class="bg-white px-4 py-3">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Pasiūlymų terminas</div>
          <div class="text-sm text-red-600 font-semibold"><%= procurement.deadline_date.strftime("%Y-%m-%d %H:%M") %></div>
        </div>
      <% end %>
    </div>

    <% if procurement.estimated_value.present? || procurement.contract_duration.present? %>
      <div class="grid grid-cols-2 gap-px bg-gray-100">
        <% if procurement.estimated_value %>
          <div class="bg-white px-4 py-3">
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Numatoma vertė</div>
            <div class="text-base text-green-600 font-bold">
              <%= number_to_currency(procurement.estimated_value, unit: "€", format: "%n %u") %>
            </div>
          </div>
        <% end %>

        <% if procurement.contract_duration.present? %>
          <div class="bg-white px-4 py-3">
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Sutarties trukmė</div>
            <div class="text-sm text-gray-900"><%= procurement.contract_duration %></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Description -->
  <% if procurement.description.present? %>
    <div class="bg-gray-50 px-4 py-3 border-t border-gray-200">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Aprašymas</div>
      <p class="text-sm text-gray-700 line-clamp-3">
        <%= truncate(procurement.description, length: 200) %>
      </p>
    </div>
  <% end %>

  <!-- Footer with Action Button -->
  <div class="bg-gray-50 px-4 py-3 border-t border-gray-200 rounded-b-xl">
    <%= link_to procurement_path(procurement),
      class: "inline-flex items-center justify-center w-full px-4 py-2 bg-gradient-to-r from-orange-500 to-red-500 text-white text-sm font-semibold rounded-lg hover:from-orange-600 hover:to-red-600 transition-colors" do %>
      Peržiūrėti išsamiau
      <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>
</div>
